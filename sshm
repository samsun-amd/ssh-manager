#!/bin/bash

# Configuration
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
DEFAULT_PRIVATE_CONFIG="$HOME/note/ssh_remote.json"
EXAMPLE_CONFIG="$SCRIPT_DIR/ssh_remote.json"
DEFAULT_SSH_PORT=22

# Directory transfer tuning (all overridable via environment).
# Directories are streamed with `tar | ssh tar -x` instead of `scp -r`, which is
# far faster for trees with many small files over slow links (e.g. BMC/SMC).
SSHM_TAR_THRESHOLD="${SSHM_TAR_THRESHOLD:-10485760}"   # bytes; compress only when >= this size
SSHM_COMPRESSED_RATIO="${SSHM_COMPRESSED_RATIO:-70}"   # percent; skip gzip if already-compressed bytes >= this
SSHM_PROGRESS="${SSHM_PROGRESS:-auto}"                 # auto = use pv when available; off = no progress bar
SSHM_FORCE_COMPRESS="${SSHM_FORCE_COMPRESS:-0}"        # 1 = always gzip the tar stream
SSHM_NO_COMPRESS="${SSHM_NO_COMPRESS:-0}"              # 1 = never gzip the tar stream

# File extensions whose contents are already compressed; re-compressing them
# wastes CPU for negligible size gain, so the tar stream skips gzip for them.
ALREADY_COMPRESSED_EXT="gz tgz bz2 tbz2 xz txz zst zip 7z rar lz4 jpg jpeg png gif webp heic mp4 mkv mov avi webm mp3 flac ogg opus aac pdf apk deb rpm jar"

if [[ -n "${SSHM_CONFIG:-}" ]]; then
    JSON_FILE="$SSHM_CONFIG"
elif [[ -r "$DEFAULT_PRIVATE_CONFIG" ]]; then
    JSON_FILE="$DEFAULT_PRIVATE_CONFIG"
else
    JSON_FILE="$EXAMPLE_CONFIG"
fi

# Dependency Check
for cmd in jq sshpass; do
    if ! command -v "$cmd" &> /dev/null; then
        echo "Error: '$cmd' is not installed."
        exit 1
    fi
done

RED='\033[1;31m'
GREEN='\033[1;32m'
NC='\033[0m'

print_error() {
    echo -e "${RED}Error: $*${NC}" >&2
}

shell_quote() {
    printf "%q" "$1"
}

validate_config() {
    if [[ ! -f "$JSON_FILE" ]]; then
        print_error "Config file not found: $JSON_FILE"
        echo "Set SSHM_CONFIG=/path/to/ssh_remote.json or create $DEFAULT_PRIVATE_CONFIG." >&2
        exit 1
    fi

    if [[ ! -r "$JSON_FILE" ]]; then
        print_error "Config file is not readable: $JSON_FILE"
        exit 1
    fi

    if ! jq -e 'type == "array"' "$JSON_FILE" > /dev/null; then
        print_error "Config file must be a valid JSON array: $JSON_FILE"
        exit 1
    fi
}

build_proxy_command() {
    local ju=$1 jp=$2 ji=$3 jport=${4:-$DEFAULT_SSH_PORT}

    if [[ -n "$jp" && "$jp" != "null" ]]; then
        printf "sshpass -p %q ssh -p %q -W %%h:%%p -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null -o LogLevel=ERROR %q@%q" \
            "$jp" "$jport" "$ju" "$ji"
    else
        printf "ssh -p %q -W %%h:%%p -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null -o LogLevel=ERROR %q@%q" \
            "$jport" "$ju" "$ji"
    fi
}

ssh_with_optional_password() {
    local password=$1
    shift

    if [[ -n "$password" && "$password" != "null" ]]; then
        sshpass -p "$password" ssh "$@"
    else
        ssh "$@"
    fi
}

scp_with_optional_password() {
    local password=$1
    shift

    if [[ -n "$password" && "$password" != "null" ]]; then
        sshpass -p "$password" scp "$@"
    else
        scp "$@"
    fi
}

# Shared sh snippet: given a directory path in $1, set shell vars `t` (total
# bytes) and `c` (bytes belonging to already-compressed file types). Used both
# locally (upload) and over ssh (download) so the sizing logic stays identical.
# Best-effort: where `find -printf` is unavailable, `c` is 0, which simply means
# "compress large dirs" (the safe default).
_dir_size_snippet() {
    cat <<EOF
t=\$(du -sk "\$1" 2>/dev/null | awk '{print \$1*1024; exit}')
c=\$(find "\$1" -type f -printf '%s %f\n' 2>/dev/null | awk -v env_exts="$ALREADY_COMPRESSED_EXT" '
  BEGIN { n=split(env_exts, E, " "); for (k=1;k<=n;k++) M[E[k]]=1 }
  { sz=\$1; name=\$2; q=split(name, A, "."); ext=(q>1)?tolower(A[q]):""; if (ext in M) acc+=sz }
  END { print acc+0 }')
EOF
}

# Program (for local use) that prints "<total_bytes> <compressed_bytes>" for the
# directory passed as $1.
local_dir_stat_program() {
    _dir_size_snippet
    printf 'echo "${t:-0} ${c:-0}"\n'
}

# Program (for remote use over ssh) that prints
# "<has_tar> <is_dir> <total_bytes> <compressed_bytes>" for the path in $1.
# A single round trip answers every download decision.
remote_dir_probe_program() {
    cat <<'EOF'
if command -v tar >/dev/null 2>&1; then ht=1; else ht=0; fi
if [ -d "$1" ]; then isdir=1; else isdir=0; fi
EOF
    printf 'if [ "$isdir" = 1 ]; then\n'
    _dir_size_snippet
    printf 'else t=0; c=0; fi\n'
    printf 'echo "$ht $isdir ${t:-0} ${c:-0}"\n'
}

# Program (for remote use over ssh) that prints "1" if tar is on PATH, else "0".
remote_has_tar_program() {
    printf 'if command -v tar >/dev/null 2>&1; then echo 1; else echo 0; fi\n'
}

# Decide whether to gzip the tar stream given measured directory stats.
# Echoes "z" to enable gzip, or "" to use a plain tar.
decide_compression() {
    local total=${1:-0} compressed=${2:-0}

    [[ "$SSHM_NO_COMPRESS" == "1" ]] && { printf ""; return; }
    [[ "$SSHM_FORCE_COMPRESS" == "1" ]] && { printf "z"; return; }

    # Too small to be worth the CPU.
    if [[ ! "$total" =~ ^[0-9]+$ ]] || (( total < SSHM_TAR_THRESHOLD )); then
        printf ""
        return
    fi

    # Already mostly compressed content: re-compressing is wasted CPU.
    if [[ "$compressed" =~ ^[0-9]+$ ]] && (( total > 0 && compressed * 100 / total >= SSHM_COMPRESSED_RATIO )); then
        printf ""
        return
    fi

    printf "z"
}

# Whether to show a pv progress bar for stream transfers.
progress_enabled() {
    [[ "$SSHM_PROGRESS" != "off" ]] && command -v pv &> /dev/null
}

# Pass-through pipe stage that shows a progress bar when pv is available.
# With a known size ($1) it shows percent/ETA; with an empty size it shows
# throughput only. Falls back to `cat` so the pipeline shape stays constant.
maybe_pv() {
    local size=$1
    if progress_enabled; then
        if [[ -n "$size" && "$size" != "0" ]]; then
            pv -s "$size"
        else
            pv
        fi
    else
        cat
    fi
}


validate_port() {
    local label=$1 port=$2

    if [[ -z "$port" || "$port" == "null" || ! "$port" =~ ^[0-9]+$ ]] || (( 10#$port < 1 || 10#$port > 65535 )); then
        print_error "Invalid SSH port for $label: $port"
        return 1
    fi

    return 0
}

resolve_target_port() {
    local configured_port=${1:-$DEFAULT_SSH_PORT}

    if [[ -n "$PORT_OVERRIDE" ]]; then
        printf "%s\n" "$PORT_OVERRIDE"
    else
        printf "%s\n" "$configured_port"
    fi
}

format_endpoint() {
    local host=$1 port=${2:-$DEFAULT_SSH_PORT}

    if [[ "$host" == *:* && "$host" != \[*\] ]]; then
        host="[$host]"
    fi

    if [[ "$port" == "$DEFAULT_SSH_PORT" ]]; then
        printf "%s" "$host"
    else
        printf "%s:%s" "$host" "$port"
    fi
}

stderr_matches() {
    local file=$1 pattern=$2
    [[ -f "$file" ]] && grep -Eqi "$pattern" "$file"
}

report_ssh_failure() {
    local exit_code=$1 user=$2 ip=$3 port=$4 err_file=$5 action=$6
    local endpoint

    endpoint=$(format_endpoint "$ip" "$port")

    [[ $exit_code -eq 0 ]] && return 1

    if stderr_matches "$err_file" "Permission denied|Authentication failed|invalid/incorrect password"; then
        print_error "SSH authentication failed for $user@$endpoint during $action. Check username/password."
        return 0
    fi

    if [[ $exit_code -eq 255 ]] || stderr_matches "$err_file" "Could not resolve hostname|Name or service not known|Connection refused|No route to host|Connection timed out|Operation timed out|Connection closed|Connection reset|Network is unreachable|Host key verification failed|kex_exchange_identification"; then
        print_error "SSH connection failed for $user@$endpoint during $action."
        return 0
    fi

    return 1
}

make_error_file() {
    mktemp "${TMPDIR:-/tmp}/sshm_error.XXXXXX"
}

cleanup_error_file() {
    local err_file=$1
    [[ -n "$err_file" && -f "$err_file" ]] && rm -f "$err_file"
}

validate_connection_fields() {
    local label=$1 user=$2 password=$3 ip=$4 port=${5:-$DEFAULT_SSH_PORT}

    if [[ -z "$user" || "$user" == "null" || -z "$ip" || "$ip" == "null" ]]; then
        print_error "Incomplete connection config for $label."
        return 1
    fi

    validate_port "$label" "$port" || return 1

    return 0
}

load_default_connection() {
    local node=$1 label=$2 node_type

    node_type=$(echo "$node" | jq -r '.type // empty')
    case "$node_type" in
        client|smc)
            TARGET_USER=$(echo "$node" | jq -r '.user // empty')
            TARGET_PASS=$(echo "$node" | jq -r '.pass // empty')
            TARGET_IP=$(echo "$node" | jq -r '.ip // empty')
            TARGET_PORT=$(echo "$node" | jq -r '.port // 22')
            ;;
        server)
            TARGET_USER=$(echo "$node" | jq -r '.bmc.user // empty')
            TARGET_PASS=$(echo "$node" | jq -r '.bmc.pass // empty')
            TARGET_IP=$(echo "$node" | jq -r '.bmc.ip // empty')
            TARGET_PORT=$(echo "$node" | jq -r '.bmc.port // 22')
            ;;
        *)
            print_error "Unsupported node type '$node_type' for $label."
            return 1
            ;;
    esac

    validate_connection_fields "$label" "$TARGET_USER" "$TARGET_PASS" "$TARGET_IP" "$TARGET_PORT"
}

run_selected_action() {
    local user=$1 password=$2 ip=$3 configured_port=${4:-$DEFAULT_SSH_PORT}
    shift 4

    local target_port
    target_port=$(resolve_target_port "$configured_port")

    if [[ "$SCP_MODE" == "true" ]]; then
        do_scp "$user" "$password" "$ip" "$target_port" "$@"
    else
        do_ssh "$user" "$password" "$ip" "$target_port" "$@"
    fi
}

print_usage() {
    echo "SSH Manager - Remote Access Tool"
    echo "--------------------------------"
    echo "Usage:"
    echo "  $(basename "$0") [-p] [-c \"command\"] <IP>                 : SSH to IP"
    echo "  $(basename "$0") [-p] [-c \"command\"] <Name|Num>           : SSH to ServerBMC|Client"
    echo "  $(basename "$0") [-p] [-c \"command\"] <Name|Num> host<N>   : SSH to ServerHost (NIC)"
    echo "  $(basename "$0") [-p] [-c \"command\"] <Name|Num> smc       : SSH to SMC via BMC"
    echo "  $(basename "$0") [-P <port>] <Name|Num>                   : SSH using a temporary port override"
    echo "  $(basename "$0") -s <source> <dest> <Name|Num>            : SCP file transfer"
    echo "  $(basename "$0") -s <source> <dest> <Name|Num> host<N>    : SCP to ServerHost"
    echo ""
    echo "Options:"
    echo "  -p    Perform a ping check before connecting"
    echo "  -P    Override SSH port for the selected target"
    echo "  --port Override SSH port for the selected target"
    echo "  -c    Execute a remote command instead of opening interactive shell"
    echo "  -s    SCP file transfer mode (requires source and destination)"
    echo "  -h    Print this help message"
    echo "  -l    List all nodes"
    echo ""
    echo "Environment:"
    echo "  SSHM_CONFIG          Override the JSON inventory path"
    echo "  SSHM_PROGRESS        auto (default) shows a pv progress bar for directory"
    echo "                       transfers when pv is installed; set to 'off' to disable"
    echo "  SSHM_TAR_THRESHOLD   Directory size in bytes at/above which the tar stream is"
    echo "                       gzip-compressed (default 10485760 = 10MB)"
    echo "  SSHM_FORCE_COMPRESS  Set to 1 to always gzip the directory tar stream"
    echo "  SSHM_NO_COMPRESS     Set to 1 to never gzip the directory tar stream"
    echo ""
    echo "Directory transfers:"
    echo "  When the source is a directory, sshm streams it with 'tar | ssh tar -x'"
    echo "  instead of 'scp -r', which is far faster for many small files. gzip is"
    echo "  applied automatically for large, non-precompressed trees. If the remote"
    echo "  lacks tar, sshm falls back to scp -r automatically."
    echo ""
    echo "SCP Examples:"
    echo "  # Upload file to remote"
    echo "  $(basename "$0") -s local_file.txt remote:/path/to/dest/ target"
    echo ""
    echo "  # Download file from remote"
    echo "  $(basename "$0") -s remote:/path/to/file.txt local_dest/ target"
    echo ""
    echo "  # Upload directory (recursive)"
    echo "  $(basename "$0") -s local_dir/ remote:/path/to/dest/ target"
    echo ""
    echo "  # Download from server host"
    echo "  $(basename "$0") -s remote:/path/file.txt ./ server1 host1"
    echo ""
    echo "  # Upload to SMC (via BMC)"
    echo "  $(basename "$0") -s local_file.txt remote:/tmp/ server1 smc"
}

# Function to ping and then SSH
do_ssh() {
    local u=$1 p=$2 i=$3 port=${4:-$DEFAULT_SSH_PORT} ju=${5:-} jp=${6:-} ji=${7:-} jport=${8:-$DEFAULT_SSH_PORT}
    local target_endpoint jump_endpoint

    target_endpoint=$(format_endpoint "$i" "$port")
    jump_endpoint=$(format_endpoint "$ji" "$jport")

    if [[ "$PING_CHECK" == "true" ]]; then
        local ping_target="$i"
        [[ -n "$ji" ]] && ping_target="$ji"
        echo -n "Pinging $ping_target... "
        if command -v fping &> /dev/null; then
            if ! fping -c 1 -t 500 "$ping_target" > /dev/null 2>&1; then
                echo -e "${RED}OFFLINE${NC}"
                print_error "Target is not reachable. Connection aborted."
                exit 1
            fi
        else
            if ! ping -c 1 -W 1 "$ping_target" > /dev/null 2>&1; then
                echo -e "${RED}OFFLINE${NC}"
                print_error "Target is not reachable. Connection aborted."
                exit 1
            fi
        fi

        echo -e "${GREEN}ONLINE${NC}"
    fi

    local ssh_opts=(-o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null -o LogLevel=ERROR -p "$port")
    if [[ -n "$ji" ]]; then
        ssh_opts+=(-o "ProxyCommand=$(build_proxy_command "$ju" "$jp" "$ji" "$jport")")
    fi

    local err_file exit_code
    err_file=$(make_error_file) || err_file=""

    if [[ -n "$REMOTE_COMMAND" ]]; then
        if [[ -n "$ji" ]]; then
            echo -e "${GREEN}Executing command on $target_endpoint ($u) via jump host $jump_endpoint ($ju): $REMOTE_COMMAND${NC}"
        else
            echo -e "${GREEN}Executing command on $target_endpoint ($u): $REMOTE_COMMAND${NC}"
        fi

        if [[ -n "$err_file" ]]; then
            ssh_with_optional_password "$p" "${ssh_opts[@]}" "$u@$i" "$REMOTE_COMMAND" 2> >(tee "$err_file" >&2)
        else
            ssh_with_optional_password "$p" "${ssh_opts[@]}" "$u@$i" "$REMOTE_COMMAND"
        fi
        exit_code=$?
        report_ssh_failure "$exit_code" "$u" "$i" "$port" "$err_file" "command execution" || true
        cleanup_error_file "$err_file"
        exit "$exit_code"
    else
        if [[ -t 0 ]]; then
            ssh_opts+=(-tt)
        fi

        if [[ -n "$ji" ]]; then
            echo -e "${GREEN}Connecting to $target_endpoint ($u) via jump host $jump_endpoint ($ju)...${NC}"
        else
            echo -e "${GREEN}Connecting to $target_endpoint ($u)...${NC}"
        fi

        if [[ -n "$err_file" ]]; then
            ssh_with_optional_password "$p" "${ssh_opts[@]}" "$u@$i" 2> >(tee "$err_file" >&2)
        else
            ssh_with_optional_password "$p" "${ssh_opts[@]}" "$u@$i"
        fi
        exit_code=$?
        report_ssh_failure "$exit_code" "$u" "$i" "$port" "$err_file" "interactive session" || true
        cleanup_error_file "$err_file"
        exit "$exit_code"
    fi
}

# Stream a local directory to the remote with `tar | ssh tar -x`.
# Globals expected: u p i port ju jp ji jport (connection), local_path,
# remote_dest (target parent directory on the remote). Returns the transfer
# exit code; 0 on success.
stream_upload_dir() {
    local total compressed zflag stat_out
    stat_out=$(bash -c "$(local_dir_stat_program)" _ "$local_path" 2>/dev/null)
    total=${stat_out%% *}
    compressed=${stat_out##* }
    zflag=$(decide_compression "$total" "$compressed")

    local parent base q_dest
    parent=$(dirname "$local_path")
    base=$(basename "$local_path")
    q_dest=$(shell_quote "$remote_dest")

    local ssh_opts=(-o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null -o LogLevel=ERROR -p "$port")
    [[ -n "$ji" ]] && ssh_opts+=(-o "ProxyCommand=$(build_proxy_command "$ju" "$jp" "$ji" "$jport")")

    # Ensure the destination directory exists on the remote.
    ssh_with_optional_password "$p" "${ssh_opts[@]}" "$u@$i" "mkdir -p $q_dest" || return $?

    local tar_create="-c" tar_extract="-x"
    if [[ "$zflag" == "z" ]]; then
        tar_create="-cz"
        tar_extract="-xz"
        echo -e "${GREEN}Streaming directory (tar + gzip)...${NC}"
    else
        echo -e "${GREEN}Streaming directory (tar)...${NC}"
    fi
    # pv shows percent against uncompressed size when not gzipping; throughput otherwise.
    local pv_size="$total"
    [[ "$zflag" == "z" ]] && pv_size=""

    tar -C "$parent" $tar_create -f - "$base" \
        | maybe_pv "$pv_size" \
        | ssh_with_optional_password "$p" "${ssh_opts[@]}" "$u@$i" "tar $tar_extract -f - -C $q_dest"
    local codes=("${PIPESTATUS[@]}")
    # Fail if tar (first) or ssh/remote-tar (last) failed; pv exit is ignored.
    [[ "${codes[0]}" -ne 0 ]] && return "${codes[0]}"
    return "${codes[${#codes[@]}-1]}"
}

# Stream a remote directory to a local path with `ssh tar -c | tar -x`.
# Globals expected: connection vars, remote_path (remote dir), local_path
# (local parent dir), plus precomputed remote_total / remote_compressed.
stream_download_dir() {
    local zflag
    zflag=$(decide_compression "$remote_total" "$remote_compressed")

    local q_remote_parent q_remote_base
    q_remote_parent=$(shell_quote "$(dirname "$remote_path")")
    q_remote_base=$(shell_quote "$(basename "$remote_path")")

    mkdir -p "$local_path" || return $?

    local ssh_opts=(-o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null -o LogLevel=ERROR -p "$port")
    [[ -n "$ji" ]] && ssh_opts+=(-o "ProxyCommand=$(build_proxy_command "$ju" "$jp" "$ji" "$jport")")

    local tar_create="-c" tar_extract="-x"
    if [[ "$zflag" == "z" ]]; then
        tar_create="-cz"
        tar_extract="-xz"
        echo -e "${GREEN}Streaming directory (tar + gzip)...${NC}"
    else
        echo -e "${GREEN}Streaming directory (tar)...${NC}"
    fi
    local pv_size="$remote_total"
    [[ "$zflag" == "z" ]] && pv_size=""

    ssh_with_optional_password "$p" "${ssh_opts[@]}" "$u@$i" "tar -C $q_remote_parent $tar_create -f - $q_remote_base" \
        | maybe_pv "$pv_size" \
        | tar $tar_extract -f - -C "$local_path"
    local codes=("${PIPESTATUS[@]}")
    [[ "${codes[0]}" -ne 0 ]] && return "${codes[0]}"
    return "${codes[${#codes[@]}-1]}"
}

# Function to perform SCP transfer
do_scp() {
    local u=$1 p=$2 i=$3 port=${4:-$DEFAULT_SSH_PORT} ju=${5:-} jp=${6:-} ji=${7:-} jport=${8:-$DEFAULT_SSH_PORT}
    local source="$SCP_SOURCE" dest="$SCP_DEST"
    local target_endpoint jump_endpoint

    target_endpoint=$(format_endpoint "$i" "$port")
    jump_endpoint=$(format_endpoint "$ji" "$jport")
    
    # Parse remote: prefix
    local upload=true
    local remote_path=""
    local local_path=""
    
    if [[ "$source" == remote:* ]]; then
        # Download: remote -> local
        upload=false
        remote_path="${source#remote:}"
        local_path="$dest"
    elif [[ "$dest" == remote:* ]]; then
        # Upload: local -> remote
        upload=true
        remote_path="${dest#remote:}"
        local_path="$source"
    else
        print_error "Either source or dest must have 'remote:' prefix."
        echo "Usage: $(basename "$0") -s <source> <dest> <target>"
        echo "  Upload:   $(basename "$0") -s local_file remote:/path/ target"
        echo "  Download: $(basename "$0") -s remote:/path/file ./ target"
        exit 1
    fi
    
    # Determine if recursive transfer needed
    local recursive_flag=""
    if [[ "$upload" == true ]]; then
        if [[ -d "$local_path" ]]; then
            recursive_flag="-r"
        elif [[ ! -e "$local_path" ]]; then
            print_error "Source file/directory '$local_path' does not exist."
            exit 1
        fi
    fi
    
    # Prepare SCP options
    local scp_opts=(-o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null -o LogLevel=ERROR -P "$port")
    if [[ -n "$ji" ]]; then
        # We can only use "scp -O" in the BMC to SMC
        scp_opts+=(-O)
        scp_opts+=(-o "ProxyCommand=$(build_proxy_command "$ju" "$jp" "$ji" "$jport")")
    fi
    
    local err_file exit_code
    err_file=$(make_error_file) || err_file=""

    if [[ "$upload" == true ]]; then
        if [[ -n "$ji" ]]; then
             echo -e "${GREEN}Uploading $local_path -> $u@$target_endpoint:$remote_path (via $jump_endpoint)...${NC}"
        else
             echo -e "${GREEN}Uploading $local_path -> $u@$target_endpoint:$remote_path${NC}"
        fi

        # Fast path: stream directories with tar instead of scp -r, when the
        # remote has tar available. Falls back to scp -r otherwise.
        if [[ -d "$local_path" ]]; then
            local remote_has_tar
            local probe_ssh_opts=(-o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null -o LogLevel=ERROR -p "$port")
            [[ -n "$ji" ]] && probe_ssh_opts+=(-o "ProxyCommand=$(build_proxy_command "$ju" "$jp" "$ji" "$jport")")
            remote_has_tar=$(ssh_with_optional_password "$p" "${probe_ssh_opts[@]}" "$u@$i" "$(remote_has_tar_program)" 2>/dev/null)

            if [[ "$remote_has_tar" == "1" ]]; then
                local remote_dest="$remote_path"
                stream_upload_dir
                exit_code=$?
                if [[ $exit_code -eq 0 ]]; then
                    echo -e "${GREEN}Transfer completed successfully${NC}"
                else
                    print_error "Directory stream transfer failed with exit code $exit_code."
                fi
                cleanup_error_file "$err_file"
                return $exit_code
            fi
            echo -e "${YELLOW}Remote 'tar' not available; falling back to scp -r.${NC}" >&2
        fi

        # Construct final command
        local cmd_flags=("${scp_opts[@]}")
        [[ -n "$recursive_flag" ]] && cmd_flags+=("$recursive_flag")

        if [[ -n "$err_file" ]]; then
            scp_with_optional_password "$p" "${cmd_flags[@]}" "$local_path" "$u@$i:$remote_path" 2> >(tee "$err_file" >&2)
        else
            scp_with_optional_password "$p" "${cmd_flags[@]}" "$local_path" "$u@$i:$remote_path"
        fi

    else
        if [[ -n "$ji" ]]; then
             echo -e "${GREEN}Downloading $u@$target_endpoint:$remote_path -> $local_path (via $jump_endpoint)...${NC}"
        else
             echo -e "${GREEN}Downloading $u@$target_endpoint:$remote_path -> $local_path${NC}"
        fi

        # One round trip answers: does the remote have tar, is the path a
        # directory, and (if so) its total/compressed byte counts.
        local ssh_opts=(-o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null -o LogLevel=ERROR -p "$port")
        if [[ -n "$ji" ]]; then
             ssh_opts+=(-o "ProxyCommand=$(build_proxy_command "$ju" "$jp" "$ji" "$jport")")
        fi

        local probe_err_file probe_exit quoted_remote_path probe_out probe_cmd
        probe_err_file=$(make_error_file) || probe_err_file=""
        quoted_remote_path=$(shell_quote "$remote_path")
        # set -- puts the path safely in $1 regardless of spaces; ssh joins args
        # with spaces, so the path must be embedded in the command string here.
        probe_cmd="set -- $quoted_remote_path; $(remote_dir_probe_program)"
        if [[ -n "$probe_err_file" ]]; then
            probe_out=$(ssh_with_optional_password "$p" "${ssh_opts[@]}" "$u@$i" "$probe_cmd" 2> >(tee "$probe_err_file" >&2))
        else
            probe_out=$(ssh_with_optional_password "$p" "${ssh_opts[@]}" "$u@$i" "$probe_cmd")
        fi
        probe_exit=$?
        if [[ $probe_exit -ne 0 ]]; then
            report_ssh_failure "$probe_exit" "$u" "$i" "$port" "$probe_err_file" "remote path probe" || \
                print_error "Unable to probe remote path '$remote_path' for $u@$target_endpoint. Exit code: $probe_exit."
            cleanup_error_file "$probe_err_file"
            cleanup_error_file "$err_file"
            return "$probe_exit"
        fi
        cleanup_error_file "$probe_err_file"

        local remote_has_tar remote_is_dir remote_total remote_compressed
        read -r remote_has_tar remote_is_dir remote_total remote_compressed <<< "$probe_out"

        # Fast path: stream a remote directory with tar when both ends have it.
        if [[ "$remote_is_dir" == "1" ]]; then
            if [[ "$remote_has_tar" == "1" ]] && command -v tar &> /dev/null; then
                stream_download_dir
                exit_code=$?
                if [[ $exit_code -eq 0 ]]; then
                    echo -e "${GREEN}Transfer completed successfully${NC}"
                else
                    print_error "Directory stream transfer failed with exit code $exit_code."
                fi
                cleanup_error_file "$err_file"
                return $exit_code
            fi
            echo -e "${YELLOW}tar not available on both ends; falling back to scp -r.${NC}" >&2
            recursive_flag="-r"
        fi

        local cmd_flags=("${scp_opts[@]}")
        [[ -n "$recursive_flag" ]] && cmd_flags+=("$recursive_flag")
        
        if [[ -n "$err_file" ]]; then
            scp_with_optional_password "$p" "${cmd_flags[@]}" "$u@$i:$remote_path" "$local_path" 2> >(tee "$err_file" >&2)
        else
            scp_with_optional_password "$p" "${cmd_flags[@]}" "$u@$i:$remote_path" "$local_path"
        fi
    fi
    
    exit_code=$?
    if [[ $exit_code -eq 0 ]]; then
        echo -e "${GREEN}Transfer completed successfully${NC}"
    else
        report_ssh_failure "$exit_code" "$u" "$i" "$port" "$err_file" "SCP transfer" || \
            print_error "SCP transfer failed with exit code $exit_code."
    fi
    cleanup_error_file "$err_file"
    return $exit_code
}

# --- Parse Arguments ---
PING_CHECK="false"
REMOTE_COMMAND=""
REMOTE_COMMAND_SET="false"
SCP_MODE="false"
SCP_SOURCE=""
SCP_DEST=""
PORT_OVERRIDE=""
ARGS=()

# Process flags first
while [[ $# -gt 0 ]]; do
    case "$1" in
        -p) PING_CHECK="true"; shift ;;
        -P|--port)
            if [[ $# -lt 2 || -z "${2:-}" ]]; then
                print_error "$1 flag requires a port."
                exit 1
            fi
            validate_port "CLI override" "$2" || exit 1
            PORT_OVERRIDE="$2"
            shift 2
            ;;
        --port=*)
            port_value="${1#--port=}"
            validate_port "CLI override" "$port_value" || exit 1
            PORT_OVERRIDE="$port_value"
            shift
            ;;
        -l|list|--list) ARGS+=("$1"); shift ;;
        -c)
            if [[ $# -lt 2 || -z "${2:-}" ]]; then
                print_error "-c flag requires a non-empty command."
                exit 1
            fi
            REMOTE_COMMAND="$2"
            REMOTE_COMMAND_SET="true"
            shift 2
            ;;
        -s)
            if [[ $# -lt 3 || -z "${2:-}" || -z "${3:-}" ]]; then
                print_error "-s flag requires both source and destination arguments."
                echo "Usage: $(basename "$0") -s <source> <dest> <target>" >&2
                exit 1
            fi
            SCP_MODE="true"
            SCP_SOURCE="$2"
            SCP_DEST="$3"
            shift 3
            ;;
        -h|help|--help) print_usage; exit 0 ;;
        -*)
            print_error "Unknown option '$1'."
            print_usage
            exit 1
            ;;
        *) ARGS+=("$1"); shift ;;
    esac
done

# Restore positional parameters (the server name, number, or list command)
set -- "${ARGS[@]}"

# --- Main Logic ---

# If no parameters left after parsing flags, show help
if [[ -z "$1" ]]; then
    if [[ "$REMOTE_COMMAND_SET" == "true" || "$SCP_MODE" == "true" ]]; then
        print_error "A target is required."
        print_usage
        exit 1
    fi
    print_usage
    exit 0
fi

validate_config

# 1. LIST COMMAND
if [[ "$1" == "list" || "$1" == "-l" || "$1" == "--list" ]]; then
    if [[ $# -ne 1 ]]; then
        print_error "List command does not accept additional arguments."
        exit 1
    fi

    # Combine Header and Data into a single stream for 'column'
    (
        echo "Num|Type|Name|IP(s)"
        echo "---|---|---|---"
        jq -r '
            def port($node): ($node.port // 22);
            def endpoint($node): if ((port($node) | tostring) == "22") then $node.ip else "\($node.ip):\(port($node))" end;
            to_entries | .[] |
            if .value.type == "client" then
                "\(.key + 1)|Client|\(.value.name)|\(endpoint(.value))"
            elif .value.type == "smc" then
                "\(.key + 1)|SMC|\(.value.name)|\(endpoint(.value)) (via BMC)"
            elif .value.type == "server" then
                "\(.key + 1)|Server|\(.value.name)|BMC: \(endpoint(.value.bmc)), Hosts: \((.value.hosts // []) | map(endpoint(.)) | join(","))"
            else
                "\(.key + 1)|Unknown|\(.value.name // "unnamed")|Unsupported node type"
            end
        ' "$JSON_FILE"
    ) | column -t -s '|'
    exit 0
fi

# 2. SINGLE PARAMETER (Number, IP, or Name)
if [[ $# -eq 1 ]]; then
    input="$1"

    # A. Number
    if [[ "$input" =~ ^[0-9]+$ ]]; then
        if (( 10#$input < 1 )); then
            print_error "Node number must be greater than 0."
            exit 1
        fi
        idx=$((10#$input - 1))
        node=$(jq ".[$idx]" "$JSON_FILE")
        [[ "$node" == "null" ]] && { print_error "Node $input not found."; exit 1; }

        load_default_connection "$node" "node $input" || exit 1
        run_selected_action "$TARGET_USER" "$TARGET_PASS" "$TARGET_IP" "$TARGET_PORT"
        exit 0
    fi

    # B. IP Search
    found=$(jq -r --arg ip "$input" '
        (.[] | select(.type=="client" and .ip==$ip) | {u:.user, p:(.pass // ""), i:.ip, port:(.port // 22)}) //
        (.[] | select(.type=="smc" and .ip==$ip) | {u:.user, p:(.pass // ""), i:.ip, port:(.port // 22)}) //
        (.[] | select(.type=="server") | .bmc | select(.ip==$ip) | {u:.user, p:(.pass // ""), i:.ip, port:(.port // 22)}) //
        (.[] | select(.type=="server") | .hosts[]? | select(.ip==$ip) | {u:.user, p:(.pass // ""), i:.ip, port:(.port // 22)})
    ' "$JSON_FILE")
    if [[ -n "$found" ]]; then
        u=$(echo "$found" | jq -r .u)
        p=$(echo "$found" | jq -r .p)
        i=$(echo "$found" | jq -r .i)
        port=$(echo "$found" | jq -r .port)
        validate_connection_fields "$input" "$u" "$p" "$i" "$port" || exit 1
        run_selected_action "$u" "$p" "$i" "$port"
        exit 0
    fi

    # C. Name
    node=$(jq -r --arg n "$input" '.[] | select(.name == $n)' "$JSON_FILE")
    if [[ -n "$node" ]]; then
        load_default_connection "$node" "$input" || exit 1
        run_selected_action "$TARGET_USER" "$TARGET_PASS" "$TARGET_IP" "$TARGET_PORT"
        exit 0
    fi
    print_error "Target '$input' not found."
    exit 1
fi

# 3. TWO PARAMETERS (Identifier + Target)
if [[ $# -eq 2 ]]; then
    identifier="$1"
    target="$2"
    
    if [[ "$identifier" =~ ^[0-9]+$ ]]; then
        if (( 10#$identifier < 1 )); then
            print_error "Node number must be greater than 0."
            exit 1
        fi
        idx=$((10#$identifier - 1))
        node=$(jq ".[$idx]" "$JSON_FILE")
    else
        node=$(jq -r --arg n "$identifier" '.[] | select(.name == $n)' "$JSON_FILE")
    fi

    [[ "$node" == "null" || -z "$node" ]] && { print_error "'$identifier' not found."; exit 1; }

    if [[ "$target" == "bmc" ]]; then
        u=$(echo "$node" | jq -r '.bmc.user')
        p=$(echo "$node" | jq -r '.bmc.pass // empty')
        i=$(echo "$node" | jq -r '.bmc.ip')
        port=$(echo "$node" | jq -r '.bmc.port // 22')
        validate_connection_fields "$identifier bmc" "$u" "$p" "$i" "$port" || exit 1
        run_selected_action "$u" "$p" "$i" "$port"
    elif [[ "$target" == "smc" ]]; then
        # Get BMC information as jump host
        bmc_user=$(echo "$node" | jq -r '.bmc.user')
        bmc_pass=$(echo "$node" | jq -r '.bmc.pass // empty')
        bmc_ip=$(echo "$node" | jq -r '.bmc.ip')
        bmc_port=$(echo "$node" | jq -r '.bmc.port // 22')
        
        if ! validate_connection_fields "$identifier BMC jump host" "$bmc_user" "$bmc_pass" "$bmc_ip" "$bmc_port"; then
            print_error "'$identifier' is not a server with BMC. SMC requires a BMC jump host."
            exit 1
        fi
        
        # Get SMC information from config
        smc_node=$(jq -r '.[] | select(.type == "smc")' "$JSON_FILE")
        if [[ -z "$smc_node" ]]; then
            print_error "No SMC node found in configuration."
            exit 1
        fi
        
        smc_user=$(echo "$smc_node" | jq -r '.user')
        smc_pass=$(echo "$smc_node" | jq -r '.pass // empty')
        smc_ip=$(echo "$smc_node" | jq -r '.ip')
        smc_port=$(echo "$smc_node" | jq -r '.port // 22')
        validate_connection_fields "SMC" "$smc_user" "$smc_pass" "$smc_ip" "$smc_port" || exit 1
        run_selected_action "$smc_user" "$smc_pass" "$smc_ip" "$smc_port" "$bmc_user" "$bmc_pass" "$bmc_ip" "$bmc_port"
    elif [[ "$target" =~ ^host([0-9]+)$ ]]; then
        host_number=${BASH_REMATCH[1]}
        if (( 10#$host_number < 1 )); then
            print_error "Host number must be greater than 0."
            exit 1
        fi
        idx=$((10#$host_number - 1))
        host_data=$(echo "$node" | jq ".hosts[$idx]")
        [[ "$host_data" == "null" ]] && { print_error "$target not defined."; exit 1; }
        u=$(echo "$host_data" | jq -r '.user')
        p=$(echo "$host_data" | jq -r '.pass // empty')
        i=$(echo "$host_data" | jq -r '.ip')
        port=$(echo "$host_data" | jq -r '.port // 22')
        validate_connection_fields "$identifier $target" "$u" "$p" "$i" "$port" || exit 1
        run_selected_action "$u" "$p" "$i" "$port"
    else
        print_error "Unknown target '$target'."
        exit 1
    fi
    exit 0
fi

print_error "Too many arguments."
print_usage
exit 1
